generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id_usuario     Int                @id @default(autoincrement())
  nombre         String             @db.VarChar(150)
  nombre_usuario String?            @unique @db.VarChar(80)
  email          String             @unique @db.VarChar(150)
  contrasena     String             @map("contraseña") @db.VarChar(255)
  telefono       String?            @db.VarChar(30)
  rol            String             @db.VarChar(50)
  creado         DateTime?          @default(now())
  actualizado    DateTime?          @updatedAt
  analisis       Analisis_Evento[]
  conversaciones Conversacion[]
  favoritos      Favoritos[]
  interacciones  Item_interaccion[]
  itinerarios    Itinerario[]
  pref_usuario   Pref_usuario?

  @@map("Usuario")
}

model Pref_usuario {
  id_usuario_preference Int      @id @default(autoincrement())
  presupuesto           Int?
  modo_transporte       String?  @db.VarChar(50)
  accesibilidad         String?  @db.VarChar(50)
  con_ninos             Boolean? @map("con_niños")
  estilo_viaje          String?  @db.VarChar(50)
  intereses             String?  @db.VarChar(500)
  id_usuario            Int      @unique
  usuario               Usuario  @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@map("Pref_usuario")
}

model Comunidad {
  id_CCAA    Int         @id @default(autoincrement())
  nombre     String      @unique @db.VarChar(50)
  slug       String      @unique @db.VarChar(80)
  provincias Provincia[]

  @@map("Comunidad")
}

model Provincia {
  id_provincia Int         @id @default(autoincrement())
  nombre       String      @db.VarChar(80)
  slug         String      @db.VarChar(80)
  id_CCAA      Int
  municipios   Municipio[]
  comunidad    Comunidad   @relation(fields: [id_CCAA], references: [id_CCAA], onDelete: Cascade)

  @@unique([id_CCAA, nombre])
  @@map("Provincia")
}

model Municipio {
  id_municipio Int       @id @default(autoincrement())
  nombre       String    @db.VarChar(300)
  latitud      Float?
  longitud     Float?
  id_provincia Int
  eventos      Evento[]
  provincia    Provincia @relation(fields: [id_provincia], references: [id_provincia], onDelete: Cascade)
  pois         Poi[]

  @@unique([id_provincia, nombre])
  @@map("Municipio")
}

model Categoria_poi {
  id_categoria_poi Int    @id @default(autoincrement())
  nombre           String @unique @db.VarChar(50)
  slug             String @unique @db.VarChar(80)
  pois             Poi[]

  @@map("Categoria_poi")
}

model Poi {
  id_poi           Int                   @id @default(autoincrement())
  nombre           String                @db.VarChar(400)
  tipo             String                @db.VarChar(80)
  subcategoria     String?               @db.VarChar(150)
  direccion        String?               @db.VarChar(300)
  latitud          Float?
  longitud         Float?
  descripcion      String?               @db.VarChar(1500)
  temporada        String?               @db.VarChar(80)
  puntuacion       Float?
  popularidad      Float?
  id_cluster       String?               @db.VarChar(50)
  origen           String?               @db.VarChar(80)
  valido           Boolean?
  creado           DateTime?
  actualizado      DateTime?
  google_search_url String? @db.Text
  id_municipio     Int?
  id_categoria_poi Int
  id_global        String                @unique @db.VarChar(150)
  elementos        Elemento_Itinerario[]
  favoritos        Favoritos[]
  interacciones    Item_interaccion[]
  categoria_poi    Categoria_poi         @relation(fields: [id_categoria_poi], references: [id_categoria_poi], onDelete: Cascade)
  municipio        Municipio?            @relation(fields: [id_municipio], references: [id_municipio])
  destacados_ccaa  Poi_destacado_ccaa[]
  programaciones   Programacion_poi[]

  @@map("Poi")
}

model Programacion_poi {
  id_programacion Int      @id @default(autoincrement()) @map("id_programación")
  dia_semana      Int
  inicio          String?  @db.VarChar(10)
  fin             String?  @db.VarChar(10)
  cerrado         Boolean?
  id_poi          Int
  poi             Poi      @relation(fields: [id_poi], references: [id_poi], onDelete: Cascade)

  @@map("Programación_poi")
}

model Evento {
  id_evento    Int       @id @default(autoincrement())
  nombre       String    @db.VarChar(150)
  descripcion  String?   @db.VarChar(1000)
  inicio       DateTime?
  fin          DateTime?
  latitud      Decimal?  @db.Decimal(10, 7)
  longitud     Decimal?  @db.Decimal(10, 7)
  id_municipio Int
  origen       String?   @db.VarChar(100)
  municipio    Municipio @relation(fields: [id_municipio], references: [id_municipio], onDelete: Cascade)

  @@map("Evento")
}

model Favoritos {
  id_favoritos Int       @id @default(autoincrement())
  creado       DateTime?
  id_usuario   Int
  id_poi       Int
  poi          Poi       @relation(fields: [id_poi], references: [id_poi], onDelete: Cascade)
  usuario      Usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@unique([id_usuario, id_poi])
  @@map("Favoritos")
}

model Item_interaccion {
  id_interaccion Int       @id @default(autoincrement())
  metadata       String?   @db.VarChar(1000)
  creado         DateTime?
  tipo_accion    String?   @db.VarChar(100)
  id_usuario     Int
  id_poi         Int
  poi            Poi       @relation(fields: [id_poi], references: [id_poi], onDelete: Cascade)
  usuario        Usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@map("Item_interaccion")
}

model Analisis_Evento {
  id_analisis_evento Int       @id @default(autoincrement())
  nombre_evento      String?   @db.VarChar(100)
  tipo_entidad       String?   @db.VarChar(100)
  id_entidad         Int?
  metadata           String?   @db.VarChar(1000)
  creado             DateTime?
  id_usuario         Int
  usuario            Usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@map("Analisis_Evento")
}

model Conversacion {
  id_conversacion Int       @id @default(autoincrement())
  titulo          String?   @db.VarChar(200)
  creado          DateTime?
  id_usuario      Int
  usuario         Usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  mensajes        Mensaje[]

  @@map("Conversacion")
}

model Mensaje {
  id_mensaje      Int          @id @default(autoincrement())
  rol             String?      @db.VarChar(50)
  contenido       String?      @db.Text
  creado          DateTime?
  id_conversacion Int
  conversacion    Conversacion @relation(fields: [id_conversacion], references: [id_conversacion], onDelete: Cascade)

  @@map("Mensaje")
}

model Itinerario {
  id_itinerario Int              @id @default(autoincrement())
  titulo        String?          @db.VarChar(200)
  destino       String?          @db.VarChar(150)
  inicio        DateTime?
  fin           DateTime?
  presupuesto   Int?
  transporte    String?          @db.VarChar(50)
  accesibilidad String?          @db.VarChar(50)
  estado        String?          @db.VarChar(50)
  creado        DateTime?
  actualizado   DateTime?
  base_nombre          String?           @db.VarChar(255)
  base_direccion       String?           @db.VarChar(400)
  base_tipo            String?           @db.VarChar(80)
  base_latitud         Float?
  base_longitud        Float?
  base_place_id        String?           @db.VarChar(180)
  permite_excursiones  Boolean           @default(false)
  radio_max_km         Float?
  ia_json              Json?
  ia_resumen           String?          @db.Text
  preferencias_json    Json?
  id_usuario    Int
  dias          Dia_Itinerario[]
  restauracion_selecciones ItinerarioRestauracion[]
  eventos              Itinerario_Evento[]
  usuario       Usuario          @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)


  @@map("Itinerario")
}

model Dia_Itinerario {
  id_dia_itinerario Int                   @id @default(autoincrement())
  fecha             DateTime?
  minutos           Int?
  notas             String?               @db.VarChar(1000)
  id_itinerario     Int
  itinerario        Itinerario            @relation(fields: [id_itinerario], references: [id_itinerario], onDelete: Cascade)
  elementos         Elemento_Itinerario[]
  eventos              Itinerario_Evento[]
  restauracion_selecciones ItinerarioRestauracion[]

  @@map("Dia_Itinerario")
}

model Elemento_Itinerario {
  id_elemento_itinerario Int            @id @default(autoincrement())
  inicio                 DateTime?
  fin                    DateTime?
  orden                  Int?
  transporte             String?        @db.VarChar(50)
  tiempo_transporte      Int?
  id_dia_itinerario      Int
  id_poi                 Int
  dia_itinerario         Dia_Itinerario @relation(fields: [id_dia_itinerario], references: [id_dia_itinerario], onDelete: Cascade)
  poi                    Poi            @relation(fields: [id_poi], references: [id_poi], onDelete: Cascade)

  @@map("Elemento_Itinerario")
}

model Poi_destacado_ccaa {
  id_poi_destacado_ccaa Int      @id @default(autoincrement())
  id_poi               Int
  comunidad            String
  ciudad_fuente        String?
  provincia_fuente     String?
  poi_canonico         String
  fuente               String?
  fuente_tipo          String?
  url_fuente           String?
  prioridad_fuente     Int?
  match_confianza      Float?
  motivo               String?
  imagen_url           String?
  created_at           DateTime @default(now())

  poi Poi @relation(fields: [id_poi], references: [id_poi], onDelete: Cascade)

  @@unique([id_poi, comunidad, poi_canonico])
}

model Evento_Turistico {
  id_evento_turistico Int       @id @default(autoincrement())
  external_id         String    @unique @db.VarChar(180)
  source              String    @db.VarChar(80)

  nombre              String    @db.VarChar(300)
  descripcion         String?   @db.VarChar(2000)
  categoria           String?   @db.VarChar(100)
  subcategoria        String?   @db.VarChar(150)

  venue_nombre        String?   @db.VarChar(250)
  direccion           String?   @db.VarChar(400)
  ciudad              String?   @db.VarChar(120)
  provincia           String?   @db.VarChar(120)
  comunidad           String?   @db.VarChar(120)

  latitud             Float?
  longitud            Float?

  inicio              DateTime
  fin                 DateTime?

  imagen_url          String?   @db.VarChar(700)
  url                 String?   @db.VarChar(700)

  precio_min          Float?
  precio_max          Float?
  moneda              String?   @db.VarChar(10)

  activo              Boolean   @default(true)
  metadata_json       Json?
  google_search_url String?

  creado              DateTime  @default(now())
  actualizado         DateTime  @updatedAt
  fetched_at          DateTime  @default(now())

  itinerarios_eventos Itinerario_Evento[]

  @@index([ciudad])
  @@index([provincia])
  @@index([comunidad])
  @@index([inicio])
  @@index([latitud, longitud])
  @@map("Evento_Turistico")
}

model Itinerario_Evento {
  id_itinerario_evento Int              @id @default(autoincrement())
  id_itinerario        Int
  id_dia_itinerario    Int?
  id_evento_turistico  Int

  orden                Int?
  inicio_sugerido      DateTime?
  fin_sugerido         DateTime?
  score_recomendacion  Float?
  motivo               String?          @db.VarChar(1000)

  creado               DateTime         @default(now())

  itinerario           Itinerario        @relation(fields: [id_itinerario], references: [id_itinerario], onDelete: Cascade)
  dia_itinerario       Dia_Itinerario?   @relation(fields: [id_dia_itinerario], references: [id_dia_itinerario], onDelete: Cascade)
  evento_turistico     Evento_Turistico  @relation(fields: [id_evento_turistico], references: [id_evento_turistico], onDelete: Cascade)

  @@index([id_itinerario])
  @@index([id_dia_itinerario])
  @@index([id_evento_turistico])
  @@map("Itinerario_Evento")
}

model LugarRestauracion {
  id_lugar_restauracion Int      @id @default(autoincrement())
  proveedor             String   @db.VarChar(50)
  externalId            String   @db.VarChar(180)
  nombre                String   @db.VarChar(300)
  categoria             String?  @db.VarChar(150)
  direccion             String?  @db.VarChar(500)
  latitud               Float
  longitud              Float
  distancia             Int?
  rating                Float?
  precio                String?  @db.VarChar(50)
  url                   String?  @db.VarChar(800)
  telefono              String?  @db.VarChar(80)
  creadoEn              DateTime @default(now())
  actualizadoEn         DateTime @updatedAt

  selecciones ItinerarioRestauracion[]

  @@unique([proveedor, externalId])
  @@map("LugarRestauracion")
}

model ItinerarioRestauracion {
  id_itinerario_restauracion Int      @id @default(autoincrement())
  id_itinerario              Int
  id_dia_itinerario          Int
  momento                    String   @db.VarChar(40)
  id_lugar_restauracion      Int
  id_poi_referencia          Int?
  creadoEn                   DateTime @default(now())

  itinerario Itinerario         @relation(fields: [id_itinerario], references: [id_itinerario], onDelete: Cascade)
  dia        Dia_Itinerario     @relation(fields: [id_dia_itinerario], references: [id_dia_itinerario], onDelete: Cascade)
  lugar      LugarRestauracion  @relation(fields: [id_lugar_restauracion], references: [id_lugar_restauracion])

  @@unique([id_itinerario, id_dia_itinerario, momento])
  @@map("ItinerarioRestauracion")
}
